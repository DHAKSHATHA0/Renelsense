# Railway Environment Variables Template
# Copy these to Railway Dashboard > Variables

# Core App Settings
PORT=3000
NODE_ENV=production

# Database (Railway will provide DATABASE_URL automatically)
# DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
SERVER_IP=0.0.0.0

# ML API Configuration (adjust if ML service runs separately)
ML_API_IP=127.0.0.1
ML_API_PORT=5000

# Optional: Google Gemini AI API Key for enhanced chatbot
# GOOGLE_AI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# Database Configuration (if using custom DB)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=kidney_monitoring
# DB_PORT=3306